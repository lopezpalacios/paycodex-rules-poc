{
  "name": "paycodex-rules-poc",
  "version": "0.1.0",
  "description": "Rule-driven interest-bearing deposit factory. Hardhat + AssemblyScript WASM + Besu.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "wasm:build": "asc wasm/assembly/index.ts --target release --outFile wasm/build/release.wasm --textFile wasm/build/release.wat --bindings esm",
    "wasm:build:debug": "asc wasm/assembly/index.ts --target debug --outFile wasm/build/debug.wasm --bindings esm",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "validate:rules": "node scripts/validate-rules.mjs",
    "qa": "npm run lint:sol && npm run validate:rules && npm run wasm:build && npm run compile && npm test",
    "besu:up": "docker compose -f besu/docker-compose.yml up -d",
    "besu:down": "docker compose -f besu/docker-compose.yml down",
    "besu:logs": "docker compose -f besu/docker-compose.yml logs -f",
    "deploy": "hardhat run scripts/deploy.ts",
    "simulate": "node scripts/simulate.mjs",
    "compare": "hardhat run scripts/compare.ts",
    "ui": "vite ui",
    "ui:build": "vite build ui"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/node": "^20.11.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "assemblyscript": "^0.27.29",
    "ethers": "^6.11.1",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^2.2.0",
    "solhint": "^5.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
