{
  "name": "paycodex-rules-poc",
  "version": "0.1.0",
  "description": "Rule-driven interest-bearing deposit factory. Hardhat + AssemblyScript WASM + Besu.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:foundry": "forge test",
    "test:fuzz": "forge test --fuzz-runs 1000",
    "wasm:build": "asc wasm/assembly/index.ts --target release --outFile wasm/build/release.wasm --textFile wasm/build/release.wat --bindings esm",
    "wasm:build:debug": "asc wasm/assembly/index.ts --target debug --outFile wasm/build/debug.wasm --bindings esm",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "validate:rules": "hardhat validate:rules",
    "coverage": "hardhat coverage",
    "wasm:test": "node wasm/tests/run.mjs",
    "qa": "npm run lint:sol && npm run validate:rules && npm run wasm:build && npm run wasm:test && npm run compile && npm test",
    "healthcheck": "bash scripts/healthcheck.sh",
    "healthcheck:fast": "bash scripts/healthcheck.sh --fast",
    "besu:up": "docker compose -f besu/docker-compose.yml up -d",
    "besu:down": "docker compose -f besu/docker-compose.yml down",
    "besu:logs": "docker compose -f besu/docker-compose.yml logs -f",
    "deploy:all": "hardhat deploy:all",
    "bench": "hardhat bench",
    "server": "node scripts/server.mjs",
    "sign-intent": "node scripts/sign-intent.mjs",
    "simulate": "node scripts/simulate.mjs",
    "ui": "vite ui",
    "ui:build": "vite build ui"
  },
  "dependencies": {
    "ethers": "^6.11.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.10",
    "@nomicfoundation/hardhat-ignition": "^3.1.4",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.4",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.16",
    "@nomicfoundation/ignition-core": "^3.1.4",
    "@openzeppelin/contracts": "^5.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "assemblyscript": "^0.27.29",
    "chai": "^6.2.2",
    "hardhat": "^3.4.3",
    "hardhat-gas-reporter": "^2.2.0",
    "solhint": "^5.0.3",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
