root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # markdown sometimes uses double-space line breaks

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sol,ts,tsx,js,jsx,mjs,cjs,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
