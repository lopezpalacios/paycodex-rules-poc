{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["scripts/**/*", "test/**/*", "hardhat.config.ts"],
  "exclude": ["node_modules", "wasm/assembly", "artifacts", "cache", "ui/**/*"]
}
